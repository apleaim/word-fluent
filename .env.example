# .env.example
# Copy this file to .env.local for local development
# NEVER commit .env.local to GitHub — it's already in .gitignore
# Add each of these to Vercel: Settings → Environment Variables
# Add CRON_SECRET and SITE_URL to GitHub: Settings → Secrets and variables → Actions

# ── Brevo ─────────────────────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
# The verified sender email in your Brevo account
FROM_EMAIL=hello@yourdomain.com

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Add the publishable key to index.html where noted (it's safe to expose)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ── App ───────────────────────────────────────────────────────────────────────
SITE_URL=https://word-fluent.vercel.app
# A random secret string you invent — used to protect /api/send-daily
# Generate one at: https://generate-secret.vercel.app/32
CRON_SECRET=your_random_secret_string_here
